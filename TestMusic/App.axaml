<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TestMusic.App"
             xmlns:local="using:TestMusic"
             xmlns:labs="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:converters="clr-namespace:TestMusic.Converters"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <suki:SukiTheme ThemeColor="Blue" />
        <labs:ControlThemes />
        <StyleInclude Source="avares://TestMusic/Styles/Styles1.axaml" />
    </Application.Styles>

    <Application.Resources>
        <converters:SecondsToMinutesSecondsConverter x:Key="SecondsToTimeConverter" />
        <converters:CountdownTextConverter x:Key="CountdownTextConverter" />
        <converters:CountdownEnabledConverter x:Key="CountdownEnabledConverter" />
        <converters:CloseBehaviorConverter x:Key="CloseBehaviorConverter" />
    </Application.Resources>

</Application>