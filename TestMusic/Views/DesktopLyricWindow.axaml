<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:TestMusic.ViewModels"
        xmlns:suki="https://github.com/kikipoulet/SukiUI"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="150"
        x:Class="TestMusic.Views.DesktopLyricWindow"
        x:DataType="vm:DesktopLyricViewModel"
        Title="DesktopLyric"
        Width="1024" Height="140"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Styles>
        <Style Selector="Grid#ControlPanel">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Window:pointerover Grid#ControlPanel">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Border#BackgroundPlate">
            <Setter Property="Background" Value="#01000000"/> 
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Window:pointerover Border#BackgroundPlate">
            <Setter Property="Background" Value="#40000000"/>
        </Style>
    </Window.Styles>

    <Panel IsHitTestVisible="{Binding !IsLocked}">
        
        <Border Name="BackgroundPlate" CornerRadius="10" PointerPressed="OnPointerPressed"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
            <TextBlock Text="{Binding Player.CurrentLyricText}"
                       FontSize="{Binding FontSize}"
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <TextBlock Text="{Binding Player.CurrentLyricTrans}"
                       FontSize="18"
                       Foreground="#DDDDDD"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       IsVisible="{Binding Player.CurrentLyricTrans, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="3" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>
        
        <Grid Name="ControlPanel" ColumnDefinitions="Auto, *, Auto" VerticalAlignment="Top" Margin="10">
            <!--wayland上没法实现鼠标穿透，所以这个功能砍了-->
            <!--<Button Grid.Column="0" Command="{Binding ToggleLockCommand}"
                    ToolTip.Tip="锁定歌词 (锁定后鼠标穿透，需在主界面关闭重开解锁)">
                <Panel>
                    <PathIcon Data="{x:Static suki:Icons.WindowPin}" 
                              Foreground="White" Width="12"
                              IsVisible="{Binding !IsLocked}"/>
                    <PathIcon Data="{x:Static suki:Icons.WindowPinOff}" 
                              Foreground="Red" Width="12"
                              IsVisible="{Binding IsLocked}"/>
                </Panel>
            </Button>-->
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                <Button Command="{Binding Player.PlayPreviousCommand}" Classes="Basic">
                    <PathIcon Data="{x:Static suki:Icons.ChevronLeft}" Foreground="White"/>
                </Button>
                
                <Button Command="{Binding Player.TogglePlayPauseCommand}" Classes="Basic">
                    <Panel>
                        <Svg Path="/Assets/pause-1006-svgrepo-com.svg" Width="24" Height="24" Css="path { fill: white; }"
                             IsVisible="{Binding Player.IsPlayingAudio}" />
                        <Svg Path="/Assets/play-1003-svgrepo-com.svg" Width="24" Height="24" Css="path { fill: white; }"
                             IsVisible="{Binding !Player.IsPlayingAudio}" />
                    </Panel>
                </Button>

                <Button Command="{Binding Player.PlayNextCommand}" Classes="Basic">
                    <PathIcon Data="{x:Static suki:Icons.ChevronRight}" Foreground="White"/>
                </Button>
            </StackPanel>
            
            <Button Grid.Column="2" Click="OnCloseClicked" Classes="Basic" ToolTip.Tip="关闭歌词">
                <PathIcon Data="{x:Static suki:Icons.Cross}" Foreground="White" Width="12"/>
            </Button>
        </Grid>
    </Panel>
</Window>