<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:models="using:KuGou.Net.Abstractions.Models"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:localControls="using:KugouAvaloniaPlayer.Controls"
             xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             xmlns:models1="clr-namespace:KugouAvaloniaPlayer.Models"
             x:Class="KugouAvaloniaPlayer.Views.SearchView"
             x:Name="SearchRoot"
             x:DataType="vm:SearchViewModel"
             behaviors:InteractionBehaviors.AttachedToVisualTreeCommand="{Binding LoadSearchHotCommand}"
             behaviors:InteractionBehaviors.AttachedToVisualTreeCommandRunOnce="True">
    <UserControl.Styles>
        <Style Selector="ItemsControl.MainTagList ContentPresenter">
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style Selector="ItemsControl.SubTagList ContentPresenter">
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
    </UserControl.Styles>

    <suki:GlassCard Margin="15" Padding="20">
        <Grid>
            <!-- 初始空页面：仅输入框 -->
            <Grid IsVisible="{Binding !HasSearched}" RowDefinitions="Auto,Auto,*">
                <Border Grid.Row="0"
                        HorizontalAlignment="Center"
                        Margin="0,18,0,16"
                        MaxWidth="660"
                        Padding="20"
                        CornerRadius="12"
                        Background="{DynamicResource SukiPrimaryColorLow}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="搜索"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBox Text="{Binding SearchKeyword}"
                                     behaviors:InteractionBehaviors.EnterKeyCommand="{Binding SearchCommand}"
                                     Watermark="输入歌曲名、歌手名、歌单或专辑...">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                            <Button Grid.Column="1"
                                    Command="{Binding SearchCommand}"
                                    IsEnabled="{Binding IsSearching, Converter={x:Static BoolConverters.Not}}"
                                    Padding="20,0">
                                <PathIcon Data="{x:Static suki:Icons.Search}" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1"
                            IsVisible="{Binding IsLoadingHot}"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Margin="0,8,0,0">
                    <suki:Loading Width="20" Height="20" />
                    <TextBlock Text="热搜加载中..." Foreground="{DynamicResource SukiLiquid2}" />
                </StackPanel>

                <Border Grid.Row="2"
                        IsVisible="{Binding !IsLoadingHot}"
                        Margin="0,4,0,0"
                        Padding="12"
                        CornerRadius="12"
                        Background="{DynamicResource SukiPrimaryColorLow}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="热搜榜"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SukiText}" />

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl Classes="MainTagList" ItemsSource="{Binding HotCategories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models1:SearchHotTagGroup">
                                        <RadioButton Classes="Segmented"
                                                     GroupName="SearchHotMainTags"
                                                     IsChecked="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).SelectedHotMainIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={Binding Index}}"
                                                     Command="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).SelectHotMainCategoryCommand}"
                                                     CommandParameter="{Binding Index}">
                                            <TextBlock Text="{Binding Name}" />
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="280">
                            <ItemsControl Classes="SubTagList" ItemsSource="{Binding CurrentHotKeywords}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models1:SearchHotTagItem">
                                        <Button Classes="Segmented"
                                                Command="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).QuickSearchHotKeywordCommand}"
                                                CommandParameter="{Binding .}">
                                            <TextBlock Text="{Binding Keyword}" />
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid IsVisible="{Binding HasSearched}" RowDefinitions="Auto, *">
                <Grid Grid.Row="0" RowDefinitions="Auto, Auto" Margin="0,0,0,15">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5">
                            <RadioButton Content="单曲" Classes="Segmented"
                                         IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models1:SearchType.Song}}"
                                         Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Song" />
                            <RadioButton Content="歌单" Classes="Segmented"
                                         IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models1:SearchType.Playlist}}"
                                         Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Playlist" />
                            <RadioButton Content="专辑" Classes="Segmented"
                                         IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models1:SearchType.Album}}"
                                         Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Album" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="Basic"
                                Command="{Binding ClearSearchCommand}"
                                Padding="14,0"
                                Margin="10,0,0,0"
                                Cursor="Hand">
                            <TextBlock Text="清空" Foreground="{DynamicResource SukiLowText}" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto">
                        <TextBox Text="{Binding SearchKeyword}"
                                 behaviors:InteractionBehaviors.EnterKeyCommand="{Binding SearchCommand}"
                                 Watermark="输入歌曲名、歌手名、歌单或专辑...">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                            </TextBox.KeyBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding SearchCommand}"
                                IsEnabled="{Binding IsSearching, Converter={x:Static BoolConverters.Not}}"
                                Margin="10,0,0,0" Padding="20,0">
                            <PathIcon Data="{x:Static suki:Icons.Search}" />
                        </Button>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="10" IsVisible="{Binding IsSearching}">
                        <suki:Loading Width="24" Height="24" />
                        <TextBlock Text="正在搜索..." VerticalAlignment="Center" Foreground="{DynamicResource SukiLiquid2}" />
                    </StackPanel>

                    <ListBox Classes="SongList"
                             ItemsSource="{Binding Songs}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Padding="0,0,0,50">
                        <ListBox.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsSearching" />
                                <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                         ConverterParameter="{x:Static models1:SearchType.Song}" />
                                <Binding Path="!IsShowingDetail" />
                            </MultiBinding>
                        </ListBox.IsVisible>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:SongItem">
                                <localControls:SongListItemControl />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer Padding="0,0,0,-50">
                        <ScrollViewer.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsSearching" />
                                <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                         ConverterParameter="{x:Static models1:SearchType.Playlist}" />
                                <Binding Path="!IsShowingDetail" />
                            </MultiBinding>
                        </ScrollViewer.IsVisible>
                        <ItemsControl ItemsSource="{Binding Playlists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:SearchPlaylistItem">
                                    <localControls:MediaCard Cover="{Binding Cover}"
                                                             Title="{Binding Name}"
                                                             Subtitle="{Binding SongCount, StringFormat='{}{0} 首'}"
                                                             Command="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).OpenPlaylistCommand}"
                                                             CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ScrollViewer Padding="0,0,0,-50">
                        <ScrollViewer.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsSearching" />
                                <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                         ConverterParameter="{x:Static models1:SearchType.Album}" />
                                <Binding Path="!IsShowingDetail" />
                            </MultiBinding>
                        </ScrollViewer.IsVisible>
                        <ItemsControl ItemsSource="{Binding Albums}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:SearchAlbumItem">
                                    <localControls:MediaCard Cover="{Binding Cover}"
                                                             Title="{Binding Name}"
                                                             Subtitle="{Binding SongCount, StringFormat='{}{0} 首'}"
                                                             Command="{Binding #SearchRoot.((vm:SearchViewModel)DataContext).OpenAlbumCommand}"
                                                             CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <localControls:SongCollectionDetailView
                        IsVisible="{Binding IsShowingDetail}"
                        Cover="{Binding DetailCover}"
                        Title="{Binding DetailTitle}"
                        Subtitle="{Binding DetailSubTitle}"
                        Songs="{Binding DetailSongs}"
                        LoadMoreCommand="{Binding LoadMoreDetailsCommand}"
                        BackCommand="{Binding GoBackCommand}"
                        IsLoadingMore="{Binding IsLoadingMoreDetails}"
                        LoadingMoreText="加载更多..."
                        ListPadding="0,0,0,50"
                        TitleFontSize="24">
                        <localControls:SongCollectionDetailView.Actions>
                            <Button Command="{Binding CollectPlaylistCommand}"
                                    IsVisible="{Binding CanCollectDetail}"
                                    Classes="Standard Icon"
                                    ToolTip.Tip="收藏">
                                <PathIcon Data="{x:Static suki:Icons.Star}" />
                            </Button>
                        </localControls:SongCollectionDetailView.Actions>
                    </localControls:SongCollectionDetailView>
                </Grid>
            </Grid>
        </Grid>
    </suki:GlassCard>
</UserControl>
