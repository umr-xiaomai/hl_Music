<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:localControls="using:KugouAvaloniaPlayer.Controls"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             x:Class="KugouAvaloniaPlayer.Views.SearchView"
             x:DataType="vm:SearchViewModel">
    <suki:GlassCard Margin="15" Padding="20">
        <Grid RowDefinitions="Auto, *">
            <!-- 顶部搜索区域 (保持不变) -->
            <Grid Grid.Row="0" RowDefinitions="Auto, Auto" Margin="0,0,0,15">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" Spacing="5">
                    <RadioButton Content="单曲" Classes="Segmented"
                                 IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SearchType.Song}}"
                                 Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Song" />
                    <RadioButton Content="歌单" Classes="Segmented"
                                 IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SearchType.Playlist}}"
                                 Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Playlist" />
                    <RadioButton Content="专辑" Classes="Segmented"
                                 IsChecked="{Binding CurrentSearchType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:SearchType.Album}}"
                                 Command="{Binding SwitchSearchTypeCommand}" CommandParameter="Album" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnDefinitions="*, Auto">
                    <TextBox Text="{Binding SearchKeyword}" Watermark="输入歌曲名、歌手名、歌单或专辑..." Grid.Column="0" />
                    <Button Grid.Column="1" Command="{Binding SearchCommand}"
                            IsEnabled="{Binding IsSearching, Converter={x:Static BoolConverters.Not}}"
                            Margin="10,0,0,0" Padding="20,0">
                        <PathIcon Data="{x:Static suki:Icons.Search}" />
                    </Button>
                </Grid>
            </Grid>

            <!-- 搜索结果区域 -->
            <Grid Grid.Row="1">
                <!-- 加载中状态 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="10" IsVisible="{Binding IsSearching}">
                    <suki:Loading Width="24" Height="24" />
                    <TextBlock Text="正在搜索..." VerticalAlignment="Center" Foreground="{DynamicResource SukiLiquid2}" />
                </StackPanel>

                <!-- 单曲搜索结果 -->
                <ListBox Classes="SongList"
                         ItemsSource="{Binding Songs}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Padding="0,0,0,50">
                    <ListBox.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!IsSearching" />
                            <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                     ConverterParameter="{x:Static vm:SearchType.Song}" />
                            <Binding Path="!IsShowingDetail" />
                        </MultiBinding>
                    </ListBox.IsVisible>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <localControls:SongListItemControl />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 歌单搜索结果 -->
                <ScrollViewer Padding="0,0,0,-50">
                    <ScrollViewer.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!IsSearching" />
                            <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                     ConverterParameter="{x:Static vm:SearchType.Playlist}" />
                            <Binding Path="!IsShowingDetail" />
                        </MultiBinding>
                    </ScrollViewer.IsVisible>
                    <ItemsControl ItemsSource="{Binding Playlists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <localControls:MediaCard Cover="{Binding Cover}"
                                                         Title="{Binding Name}"
                                                         Subtitle="{Binding SongCount, StringFormat='{}{0} 首'}"
                                                         Command="{Binding $parent[UserControl].((vm:SearchViewModel)DataContext).OpenPlaylistCommand}"
                                                         CommandParameter="{Binding .}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 专辑搜索结果-->
                <ScrollViewer Padding="0,0,0,-50">
                    <ScrollViewer.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!IsSearching" />
                            <Binding Path="CurrentSearchType" Converter="{x:Static ObjectConverters.Equal}"
                                     ConverterParameter="{x:Static vm:SearchType.Album}" />
                            <Binding Path="!IsShowingDetail" />
                        </MultiBinding>
                    </ScrollViewer.IsVisible>
                    <ItemsControl ItemsSource="{Binding Albums}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <localControls:MediaCard Cover="{Binding Cover}"
                                                         Title="{Binding Name}"
                                                         Subtitle="{Binding SongCount, StringFormat='{}{0} 首'}"
                                                         Command="{Binding $parent[UserControl].((vm:SearchViewModel)DataContext).OpenAlbumCommand}"
                                                         CommandParameter="{Binding .}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 歌单/专辑详情页 -->
                <Grid IsVisible="{Binding IsShowingDetail}" RowDefinitions="Auto, *">
                    <!-- 详情页头部 -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,0,0,15">
                        <Border Width="80" Height="80" CornerRadius="8" ClipToBounds="True"
                                Background="{DynamicResource SukiPrimaryColorLow}">
                            <controls:AsyncImage Source="{Binding DetailCover}" Stretch="UniformToFill" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                            <TextBlock Text="{Binding DetailTitle}" FontSize="24" FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding DetailSubTitle}" FontSize="14"
                                       Foreground="{DynamicResource SukiLiquid2}" Margin="0,5,0,0" />
                        </StackPanel>

                        <!-- 收藏歌单按钮 (仅在歌单详情页显示) -->
                        <Button Grid.Column="2" Command="{Binding CollectPlaylistCommand}"
                                IsVisible="{Binding IsPlaylistDetail}"
                                Classes="Standard Icon" VerticalAlignment="Center" Margin="10,0" ToolTip.Tip="收藏">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <PathIcon Data="{x:Static suki:Icons.Star}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3" Command="{Binding GoBackCommand}" Classes="Basic"
                                VerticalAlignment="Top">
                            <PathIcon Data="{x:Static suki:Icons.ChevronLeft}"
                                      Foreground="{DynamicResource SukiLowText}" Width="28"
                                      Height="28" />
                        </Button>
                    </Grid>

                    <!-- 详情页列表 (支持翻页) -->
                    <Grid Grid.Row="1">
                        <ListBox Classes="SongList"
                                 ItemsSource="{Binding DetailSongs}"
                                 ScrollViewer.ScrollChanged="OnDetailScrollChanged"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Padding="0,0,0,50">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <localControls:SongListItemControl />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 底部 Loading -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                    Margin="10" Spacing="10"
                                    IsVisible="{Binding IsLoadingMoreDetails}">
                            <suki:Loading Width="20" Height="20" />
                            <TextBlock Text="加载更多..." VerticalAlignment="Center"
                                       Foreground="{DynamicResource SukiLiquid2}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </suki:GlassCard>
</UserControl>