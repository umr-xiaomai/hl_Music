<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
        xmlns:suki="https://github.com/kikipoulet/SukiUI"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="150"
        x:Class="KugouAvaloniaPlayer.Views.DesktopLyricWindow"
        x:DataType="vm:DesktopLyricViewModel"
        Title="DesktopLyric"
        Width="1024" Height="140"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Styles>
        <Style Selector="Grid#ControlPanel">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Window:pointerover Grid#ControlPanel">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border#BackgroundPlate">
            <Setter Property="Background" Value="#01000000" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Window:pointerover Border#BackgroundPlate">
            <Setter Property="Background" Value="#40000000" />
        </Style>

        <Style Selector="TextBlock.DesktopLine">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="{Binding FontSize}" />
            <Setter Property="FontFamily" Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).LyricFontFamily}" />
        </Style>

        <Style Selector="TextBlock.DesktopWord">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).FontSize}" />
            <Setter Property="FontFamily" Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).LyricFontFamily}" />
        </Style>

        <Style Selector="TextBlock.DesktopTrans">
            <Setter Property="FontSize" Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).TranslationFontSize}" />
            <Setter Property="FontFamily" Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).LyricFontFamily}" />
        </Style>
    </Window.Styles>

    <Panel IsHitTestVisible="{Binding !IsLocked}">

        <Border Name="BackgroundPlate" CornerRadius="10" PointerPressed="OnPointerPressed" />
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
            <TextBlock Text="{Binding Player.CurrentLyricText}"
                       Classes="KaraokeLine DesktopLine"
                       Classes.active="True"
                       Foreground="{Binding LyricForeground}"
                       IsVisible="{Binding Player.CurrentLyricLine.IsKrcWordLevel, Converter={x:Static BoolConverters.Not}}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1" />
                </TextBlock.Effect>
            </TextBlock>

            <ItemsControl ItemsSource="{Binding Player.CurrentLyricLine.Words}"
                          IsVisible="{Binding Player.CurrentLyricLine.IsKrcWordLevel}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:LyricWordViewModel">
                        <TextBlock Text="{Binding Text}"
                                   Classes="KaraokeWord DesktopWord"
                                   Classes.played="{Binding IsPlayed}"
                                   Classes.current="{Binding IsCurrent}"
                                   Foreground="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).LyricForeground}"
                                   RenderTransform="{Binding LiftOffset, Converter={StaticResource WordLiftTransformConverter}}">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding Player.CurrentLyricTrans}"
                       Classes="KaraokeTrans DesktopTrans"
                       Classes.active="True"
                       Foreground="{Binding TranslationLineForeground}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center">
                <TextBlock.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="Player.CurrentLyricTrans"
                                 Converter="{x:Static StringConverters.IsNotNullOrEmpty}" />
                        <Binding Path="Player.CurrentLyricLine.HasWordLevelTranslation"
                                 Converter="{x:Static BoolConverters.Not}" />
                    </MultiBinding>
                </TextBlock.IsVisible>
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="3" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1" />
                </TextBlock.Effect>
            </TextBlock>

            <ItemsControl ItemsSource="{Binding Player.CurrentLyricLine.TranslationWords}"
                          IsVisible="{Binding Player.CurrentLyricLine.HasWordLevelTranslation}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:LyricWordViewModel">
                        <TextBlock Text="{Binding Text}"
                                   Classes="KaraokeTransWord DesktopTrans"
                                   Classes.played="{Binding IsPlayed}"
                                   Classes.current="{Binding IsCurrent}"
                                   Foreground="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).TranslationWordForeground}"
                                   RenderTransform="{Binding LiftOffset, Converter={StaticResource WordLiftTransformConverter}}">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="3" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Grid Name="ControlPanel" ColumnDefinitions="Auto, Auto, *, Auto" VerticalAlignment="Top" Margin="10">
            <Button Grid.Column="0"
                    Command="{Binding ToggleLockCommand}"
                    IsVisible="{Binding CanMousePassthrough}"
                    Classes="Basic"
                    Cursor="Hand"
                    ToolTip.Tip="锁定后需在主界面关闭重开解锁">
                <Panel>
                    <Svg Path="/Assets/lock2-svgrepo-com.svg" Width="24" Height="24"
                         Css="path { fill: white; }"
                         IsVisible="{Binding !IsLocked}"/>
                    <Svg Path="/Assets/lock2-svgrepo-com.svg" Width="24" Height="24"
                         Css="path { fill: black; }"
                         IsVisible="{Binding IsLocked}"/>
                </Panel>
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0,0,0">
                <Button Command="{Binding DecreaseFontSizeCommand}" Classes="Basic" ToolTip.Tip="减小歌词字号">
                    <TextBlock Text="A-" Foreground="White" FontWeight="SemiBold" />
                </Button>

                <TextBlock Text="{Binding FontSizeDisplay}" Foreground="White" VerticalAlignment="Center" />

                <Button Command="{Binding IncreaseFontSizeCommand}" Classes="Basic" ToolTip.Tip="增大歌词字号">
                    <TextBlock Text="A+" Foreground="White" FontWeight="SemiBold" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                <Button Command="{Binding Player.PlayPreviousCommand}" Classes="Basic">
                    <PathIcon Data="{x:Static suki:Icons.ChevronLeft}" Foreground="White" />
                </Button>

                <Button Command="{Binding Player.TogglePlayPauseCommand}" Classes="Basic">
                    <Panel>
                        <Svg Path="/Assets/pause-1006-svgrepo-com.svg" Width="24" Height="24"
                             Css="path { fill: white; }"
                             IsVisible="{Binding Player.IsPlayingAudio}" />
                        <Svg Path="/Assets/play-1003-svgrepo-com.svg" Width="24" Height="24"
                             Css="path { fill: white; }"
                             IsVisible="{Binding !Player.IsPlayingAudio}" />
                    </Panel>
                </Button>

                <Button Command="{Binding Player.PlayNextCommand}" Classes="Basic">
                    <PathIcon Data="{x:Static suki:Icons.ChevronRight}" Foreground="White" />
                </Button>
            </StackPanel>

            <Button Grid.Column="3" Click="OnCloseClicked" Classes="Basic" ToolTip.Tip="关闭歌词">
                <PathIcon Data="{x:Static suki:Icons.Cross}" Foreground="White" Width="12" />
            </Button>
        </Grid>
    </Panel>
</Window>
