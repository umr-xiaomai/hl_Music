<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
        xmlns:suki="https://github.com/kikipoulet/SukiUI"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="150"
        x:Class="KugouAvaloniaPlayer.Views.DesktopLyricWindow"
        x:DataType="vm:DesktopLyricViewModel"
        Title="DesktopLyric"
        Width="1024" Height="140"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Styles>
        <Style Selector="Border#BackgroundPlate">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Border#BackgroundPlate.interactive">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="suki|GlassCard#ControlCard">
            <Setter Property="Width" Value="716" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsOpaque" Value="False" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0" />
            <Setter Property="RenderTransform" Value="translateY(-6px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.22" />
                    <TransformOperationsTransition Property="RenderTransform"
                                                   Duration="0:0:0.22"
                                                   Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="suki|GlassCard#ControlCard.expanded">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0)" />
        </Style>

        <Style Selector="suki|GlassCard#ControlCard.locked">
            <Setter Property="Opacity" Value="0" />
        </Style>

        <Style Selector="StackPanel#LeftControls">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="1,0.5" />
            <Setter Property="RenderTransform" Value="scaleX(1)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                    <TransformOperationsTransition Property="RenderTransform"
                                                   Duration="0:0:0.28"
                                                   Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="StackPanel#LeftControls.locked">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="scaleX(0.02)" />
        </Style>

        <Style Selector="StackPanel#RightControls">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0,0.5" />
            <Setter Property="RenderTransform" Value="scaleX(1)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                    <TransformOperationsTransition Property="RenderTransform"
                                                   Duration="0:0:0.28"
                                                   Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="StackPanel#RightControls.locked">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="scaleX(0.02)" />
        </Style>

        <Style Selector="Button#CenterLockButton">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.14" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button#CenterLockButton.locked">
            <Setter Property="Opacity" Value="0" />
        </Style>

        <Style Selector="Border#CollapsedLockBubble">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="#6C383838" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform" Value="scaleX(0.72) scaleY(0.86)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.22" />
                    <TransformOperationsTransition Property="RenderTransform"
                                                   Duration="0:0:0.28"
                                                   Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border#CollapsedLockBubble.locked">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="scaleX(1) scaleY(1)" />
        </Style>

        <Style Selector="Border#CollapsedLockBubble.locked.revealed">
            <Setter Property="Opacity" Value="0.96" />
            <Setter Property="RenderTransform" Value="scaleX(1.06) scaleY(1.04)" />
        </Style>

        <Style Selector="TextBlock.DesktopLine">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="{Binding FontSize}" />
            <Setter Property="FontFamily"
                    Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).LyricFontFamily}" />
        </Style>

        <Style Selector="TextBlock.DesktopWord">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize"
                    Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).FontSize}" />
            <Setter Property="FontFamily"
                    Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).LyricFontFamily}" />
        </Style>

        <Style Selector="TextBlock.DesktopTrans">
            <Setter Property="FontSize"
                    Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).TranslationFontSize}" />
            <Setter Property="FontFamily"
                    Value="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).LyricFontFamily}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*"
          PointerEntered="OnControlHotspotPointerEntered"
          PointerExited="OnControlHotspotPointerExited">
        <Border Grid.RowSpan="2"
                Name="BackgroundPlate"
                Classes.interactive="{Binding IsControlBarExpanded}"
                PointerPressed="OnLyricPointerPressed"
                IsHitTestVisible="{Binding IsUnlockedInteractionEnabled}" />

        <Grid Grid.Row="0"
              Width="716"
              Height="64"
              Background="Transparent"
              HorizontalAlignment="Center"
              VerticalAlignment="Top">
            <suki:GlassCard Name="ControlCard"
                            Classes.expanded="{Binding IsControlBarExpanded}"
                            Classes.locked="{Binding IsLocked}"
                            IsHitTestVisible="{Binding IsControlBarExpanded}"
                            Padding="12,10"
                            Margin="0,8,0,0"
                            Background="#8C4F4F4F"
                            BorderBrush="#26FFFFFF"
                            BorderThickness="1"
                            PointerPressed="OnControlSurfacePointerPressed">
                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto" ColumnSpacing="12">
                    <StackPanel Name="LeftControls"
                                Grid.Column="0"
                                Classes.locked="{Binding IsLocked}"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <Button Command="{Binding DecreaseFontSizeCommand}" Classes="Basic" ToolTip.Tip="减小歌词字号">
                            <TextBlock Text="A-" Foreground="White" FontWeight="SemiBold" />
                        </Button>

                        <TextBlock Text="{Binding FontSizeDisplay}"
                                   Foreground="White"
                                   VerticalAlignment="Center" />

                        <Button Command="{Binding IncreaseFontSizeCommand}" Classes="Basic" ToolTip.Tip="增大歌词字号">
                            <TextBlock Text="A+" Foreground="White" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>

                    <Button Name="CenterLockButton"
                            Grid.Column="2"
                            Classes.locked="{Binding IsLocked}"
                            Command="{Binding ToggleLockCommand}"
                            IsVisible="{Binding CanMousePassthrough}"
                            Classes="Basic"
                            Margin="75,-5,0,0"
                            Cursor="Hand"
                            ToolTip.Tip="锁定后收起为悬浮图标">
                        <Svg Path="/Assets/lock2-svgrepo-com.svg"
                             Width="22"
                             Height="22"
                             Css="path { fill: white; }" />
                    </Button>

                    <StackPanel Name="RightControls"
                                Grid.Column="4"
                                Classes.locked="{Binding IsLocked}"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="16">
                        <Button Command="{Binding Player.PlayPreviousCommand}" Classes="Basic">
                            <PathIcon Data="{x:Static suki:Icons.ChevronLeft}" Foreground="White" />
                        </Button>

                        <Button Command="{Binding Player.TogglePlayPauseCommand}" Classes="Basic">
                            <Panel>
                                <Svg Path="/Assets/pause-1006-svgrepo-com.svg"
                                     Width="24"
                                     Height="24"
                                     Css="path { fill: white; }"
                                     IsVisible="{Binding Player.IsPlayingAudio}" />
                                <Svg Path="/Assets/play-1003-svgrepo-com.svg"
                                     Width="24"
                                     Height="24"
                                     Css="path { fill: white; }"
                                     IsVisible="{Binding !Player.IsPlayingAudio}" />
                            </Panel>
                        </Button>

                        <Button Command="{Binding Player.PlayNextCommand}" Classes="Basic">
                            <PathIcon Data="{x:Static suki:Icons.ChevronRight}" Foreground="White" />
                        </Button>

                        <Button Click="OnCloseClicked" Classes="Basic" ToolTip.Tip="关闭歌词">
                            <PathIcon Data="{x:Static suki:Icons.Cross}" Foreground="White" Width="12" />
                        </Button>
                    </StackPanel>
                </Grid>
            </suki:GlassCard>

            <Border Name="CollapsedLockBubble"
                    Classes.locked="{Binding IsLocked}"
                    Classes.revealed="{Binding IsCollapsedLockIconHovered}"
                    IsVisible="{Binding IsEmbeddedCollapsedLockIconVisible}"
                    IsHitTestVisible="{Binding IsCollapsedLockIconVisible}"
                    Width="40"
                    Height="40"
                    Padding="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,12,0,0"
                    PointerEntered="OnCollapsedIconPointerEntered"
                    PointerExited="OnCollapsedIconPointerExited"
                    PointerPressed="OnCollapsedIconPointerPressed">
                <Svg Path="/Assets/lock2-svgrepo-com.svg"
                     Width="22"
                     Height="22"
                     Css="path { fill: white; }" />
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    IsHitTestVisible="False"
                    Margin="32,0">
            <TextBlock Text="{Binding Player.CurrentLyricText}"
                       Classes="KaraokeLine DesktopLine"
                       Classes.active="True"
                       Foreground="{Binding LyricForeground}"
                       IsVisible="{Binding Player.CurrentLyricLine.IsKrcWordLevel, Converter={x:Static BoolConverters.Not}}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1" />
                </TextBlock.Effect>
            </TextBlock>

            <ItemsControl ItemsSource="{Binding Player.CurrentLyricLine.Words}"
                          IsVisible="{Binding Player.CurrentLyricLine.IsKrcWordLevel}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:LyricWordViewModel">
                        <TextBlock Text="{Binding Text}"
                                   Classes="KaraokeWord DesktopWord"
                                   Classes.played="{Binding IsPlayed}"
                                   Classes.current="{Binding IsCurrent}"
                                   Foreground="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).LyricForeground}"
                                   RenderTransform="{Binding LiftOffset, Converter={StaticResource WordLiftTransformConverter}}">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding Player.CurrentLyricTrans}"
                       Classes="KaraokeTrans DesktopTrans"
                       Classes.active="True"
                       Foreground="{Binding TranslationLineForeground}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center">
                <TextBlock.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="Player.CurrentLyricTrans"
                                 Converter="{x:Static StringConverters.IsNotNullOrEmpty}" />
                        <Binding Path="Player.CurrentLyricLine.HasWordLevelTranslation"
                                 Converter="{x:Static BoolConverters.Not}" />
                    </MultiBinding>
                </TextBlock.IsVisible>
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="3" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1" />
                </TextBlock.Effect>
            </TextBlock>

            <ItemsControl ItemsSource="{Binding Player.CurrentLyricLine.TranslationWords}"
                          IsVisible="{Binding Player.CurrentLyricLine.HasWordLevelTranslation}"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:LyricWordViewModel">
                        <TextBlock Text="{Binding Text}"
                                   Classes="KaraokeTransWord DesktopTrans"
                                   Classes.played="{Binding IsPlayed}"
                                   Classes.current="{Binding IsCurrent}"
                                   Foreground="{Binding $parent[Window].((vm:DesktopLyricViewModel)DataContext).TranslationWordForeground}"
                                   RenderTransform="{Binding LiftOffset, Converter={StaticResource WordLiftTransformConverter}}">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="3" Color="Black" Opacity="0.8" OffsetX="1" OffsetY="1" />
                            </TextBlock.Effect>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Window>
