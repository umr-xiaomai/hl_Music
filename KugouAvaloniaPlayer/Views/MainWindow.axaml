<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="https://github.com/kikipoulet/SukiUI"
                 xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
                 xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
                 xmlns:localControls="clr-namespace:KugouAvaloniaPlayer.Controls"
                 mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
                 x:Class="KugouAvaloniaPlayer.Views.MainWindow"
                 MinHeight="600"
                 MinWidth="800"
                 x:DataType="vm:MainWindowViewModel"
                 Name="RootWindow"
                 Icon="/Assets/Test.ico"
                 Title="KA Music"
                 BackgroundStyle="Bubble"
                 CanFullScreen="True"
                 TitleBarVisibilityOnFullScreen="AutoHidden">

    <suki:SukiWindow.RightWindowTitleBarControls>
        <Button Classes="WindowControlsButton"
                Cursor="Hand"
                Command="{Binding NavigateToUserCommand}"
                ToolTip.Tip="设置">
            <Svg Path="/Assets/gear-svgrepo-com.svg"
                 Width="18"
                 Height="18"
                 VerticalAlignment="Center" />
        </Button>
    </suki:SukiWindow.RightWindowTitleBarControls>

    <suki:SukiWindow.Styles>
        <!-- 遮罩层动画 -->
        <Style Selector="Border#QueueBackdrop">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsVisible" Value="False" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border#QueueBackdrop.open">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- 播放列表面板动画 -->
        <Style Selector="Border#QueuePanel">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsVisible" Value="False" />
            <Setter Property="RenderTransform" Value="translateY(20px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border#QueuePanel.open">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0)" />
        </Style>

        <Style Selector="Button.SidebarPlaylistOption">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource SukiLowText}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel Background="Transparent">
                        <Border Name="OptionBackground"
                                Background="{DynamicResource SukiPrimaryColorLow}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.16" Easing="CubicEaseOut" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                        <Border Name="OptionAccent"
                                Width="3"
                                Margin="0,8,0,8"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource SukiPrimaryColor}"
                                CornerRadius="2"
                                Opacity="0">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.16" Easing="CubicEaseOut" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.SidebarPlaylistOption:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource SukiText}" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption:pointerover /template/ Border#OptionBackground">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption:pressed /template/ Border#OptionBackground">
            <Setter Property="Opacity" Value="0.75" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption.selected">
            <Setter Property="Foreground" Value="{DynamicResource SukiPrimaryColor}" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption.selected /template/ Border#OptionBackground">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.SidebarPlaylistOption.selected /template/ Border#OptionAccent">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </suki:SukiWindow.Styles>

    <!--<suki:SukiWindow.LogoContent>
        <Image Source="../Assets/Test.ico" Width="15" Height="15" />
    </suki:SukiWindow.LogoContent>-->

    <Grid Name="MainGrid">

        <suki:SukiSideMenu
            ItemsSource="{Binding Pages}"
            SelectedItem="{Binding ActivePage}"
            IsSearchEnabled="False">

            <suki:SukiSideMenu.HeaderContent>
                <Border Margin="16,10,16,14"
                        Padding="8"
                        CornerRadius="10"
                        Background="{DynamicResource SukiPrimaryColorLow}">
                    <localControls:UserAvatarControl />
                </Border>
            </suki:SukiSideMenu.HeaderContent>

            <suki:SukiSideMenu.ItemTemplate>
                <DataTemplate DataType="vm:PageViewModelBase">
                    <suki:SukiSideMenuItem Header="{Binding DisplayName}">
                        <suki:SukiSideMenuItem.Icon>
                            <Svg Path="{Binding Icon}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </suki:SukiSideMenuItem.Icon>
                    </suki:SukiSideMenuItem>
                </DataTemplate>
            </suki:SukiSideMenu.ItemTemplate>

            <suki:SukiSideMenu.FooterContent>
                <StackPanel Margin="10,4,10,80" Spacing="10">
                    <Separator Margin="0,4,0,2" />

                    <TabControl>
                        <TabItem Header="我的歌单" FontSize="12" FontWeight="SemiBold"
                                 Foreground="{DynamicResource SukiLowText}" >
                                <StackPanel Spacing="8">
                                    <ItemsControl ItemsSource="{Binding SidebarOnlinePlaylists}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:PlaylistItem">
                                                <Border Height="40" CornerRadius="8">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="删除歌单"
                                                                      Tag="{Binding .}"
                                                                      Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.DeleteOnlinePlaylistCommand}"
                                                                      CommandParameter="{Binding $self.Tag}" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Button Classes="SidebarPlaylistOption"
                                                            Classes.selected="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.SelectedPlaylist, Converter={StaticResource PlaylistSelectionConverter}, ConverterParameter={Binding .}}"
                                                            Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).OpenSidebarPlaylistCommand}"
                                                            CommandParameter="{Binding .}">
                                                        <Grid ColumnDefinitions="32,*,Auto" VerticalAlignment="Center">
                                                            <Border Width="28" Height="28" CornerRadius="6" ClipToBounds="True"
                                                                    VerticalAlignment="Center">
                                                                <controls:AsyncImage Source="{Binding Cover}"
                                                                                     Stretch="UniformToFill" />
                                                            </Border>
                                                            <TextBlock Grid.Column="1"
                                                                       Margin="10,0,0,0"
                                                                       Text="{Binding Name}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Button>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding SidebarLocalPlaylists}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:PlaylistItem">
                                                <Border Height="40" CornerRadius="8">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="编辑本地歌单"
                                                                      Tag="{Binding .}"
                                                                      Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.EditLocalPlaylistCommand}"
                                                                      CommandParameter="{Binding $self.Tag}" />
                                                            <MenuItem Header="移除本地歌单"
                                                                      Tag="{Binding .}"
                                                                      Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.DeleteLocalPlaylistCommand}"
                                                                      CommandParameter="{Binding $self.Tag}" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Button Classes="SidebarPlaylistOption"
                                                            Classes.selected="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.SelectedPlaylist, Converter={StaticResource PlaylistSelectionConverter}, ConverterParameter={Binding .}}"
                                                            Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).OpenSidebarPlaylistCommand}"
                                                            CommandParameter="{Binding .}">
                                                        <Grid ColumnDefinitions="32,*" VerticalAlignment="Center">
                                                            <Border Width="28" Height="28" CornerRadius="6" ClipToBounds="True"
                                                                    VerticalAlignment="Center">
                                                                <controls:AsyncImage Source="{Binding Cover}"
                                                                                     Stretch="UniformToFill" />
                                                            </Border>
                                                            <TextBlock Grid.Column="1"
                                                                       Margin="10,0,0,0"
                                                                       Text="{Binding Name}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Button>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Height="36"
                                            Classes="Basic"
                                            Cursor="Hand"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch">
                                        <Button.Flyout>
                                            <MenuFlyout Placement="Bottom">
                                                <MenuItem Header="导入本地文件夹..."
                                                          Command="{Binding PlaylistsViewModel.ImportLocalFolderCommand}" />
                                                <MenuItem Header="导入其他平台歌单链接..."
                                                          Command="{Binding PlaylistsViewModel.ImportExternalPlaylistCommand}" />
                                                <MenuItem Header="新建歌单..."
                                                          Command="{Binding PlaylistsViewModel.ShowCreatePlaylistDialogCommand}" />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                        <Grid ColumnDefinitions="28,*" VerticalAlignment="Center">
                                            <Border Grid.Column="0"
                                                    Width="20"
                                                    Height="20"
                                                    CornerRadius="4"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource SukiPrimaryColorLow}" />
                                            <Svg Grid.Column="0"
                                                 Path="/Assets/music-folder-8-svgrepo-com.svg"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="10,0,0,0"
                                                       Text="新建歌单"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                        </TabItem>
                        <TabItem Header="收藏的专辑">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SidebarAlbumPlaylists}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:PlaylistItem">
                                                <Border Height="40" CornerRadius="8">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="取消收藏专辑"
                                                                      Tag="{Binding .}"
                                                                      Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.DeleteOnlinePlaylistCommand}"
                                                                      CommandParameter="{Binding $self.Tag}" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Button Classes="SidebarPlaylistOption"
                                                            Classes.selected="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).PlaylistsViewModel.SelectedPlaylist, Converter={StaticResource PlaylistSelectionConverter}, ConverterParameter={Binding .}}"
                                                            Command="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).OpenSidebarPlaylistCommand}"
                                                            CommandParameter="{Binding .}">
                                                        <Grid ColumnDefinitions="32,*" VerticalAlignment="Center">
                                                            <Border Width="28" Height="28" CornerRadius="6" ClipToBounds="True"
                                                                    VerticalAlignment="Center">
                                                                <controls:AsyncImage Source="{Binding Cover}"
                                                                                     Stretch="UniformToFill" />
                                                            </Border>
                                                            <TextBlock Grid.Column="1"
                                                                       Margin="10,0,0,0"
                                                                       Text="{Binding Name}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Button>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                        </TabItem>
                    </TabControl>

                </StackPanel>
            </suki:SukiSideMenu.FooterContent>
        </suki:SukiSideMenu>

        <localControls:BottomPlaybackControl />
        <localControls:NowPlaying ZIndex="300" />

        <Border Name="QueueBackdrop"
                Grid.Row="0"
                Classes.open="{Binding IsQueuePaneOpen}"
                Background="#40000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                behaviors:InteractionBehaviors.PointerPressedCommand="{Binding CloseQueuePaneCommand}"
                IsVisible="False" />

        <Border Name="QueuePanel"
                Grid.Row="0"
                Classes.open="{Binding IsQueuePaneOpen}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Width="360"
                MinWidth="280"
                MaxWidth="460"
                MaxHeight="560"
                Margin="0,0,20,100"
                ClipToBounds="False">
            <localControls:PlaybackQueueControl />
        </Border>

    </Grid>

    <suki:SukiWindow.Hosts>
        <suki:SukiToastHost Manager="{Binding ToastManager}" />
        <suki:SukiDialogHost Manager="{Binding DialogManager}" />
    </suki:SukiWindow.Hosts>
</suki:SukiWindow>
