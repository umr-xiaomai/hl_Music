<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:models="clr-namespace:KugouAvaloniaPlayer.Models"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="620"
             x:Class="KugouAvaloniaPlayer.Views.UserView"
             x:Name="UserRoot"
             x:DataType="vm:UserViewModel">

    <UserControl.Styles>
        <Style Selector="Button.SettingsNav">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.SettingsNav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SukiPrimaryColorLow}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </UserControl.Styles>

    <suki:GlassCard Margin="24,24,24,104" Padding="20">
        <Grid ColumnDefinitions="180,*" ColumnSpacing="16">

            <Border Grid.Column="0"
                    CornerRadius="12"
                    Background="{DynamicResource SukiPrimaryColorLow}"
                    Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="设置中心"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SukiText}" />


                    <Separator Margin="0,6,0,8" />

                    <Button Classes="SettingsNav"
                            Command="{Binding SwitchSettingsSectionCommand}"
                            CommandParameter="常规">
                        <TextBlock Text="常规" Foreground="{DynamicResource SukiText}" />
                    </Button>

                    <Button Classes="SettingsNav"
                            Command="{Binding SwitchSettingsSectionCommand}"
                            CommandParameter="播放与音效">
                        <TextBlock Text="播放与音效" Foreground="{DynamicResource SukiText}" />
                    </Button>

                    <Button Classes="SettingsNav"
                            Command="{Binding SwitchSettingsSectionCommand}"
                            CommandParameter="快捷键">
                        <TextBlock Text="快捷键" Foreground="{DynamicResource SukiText}" />
                    </Button>

                    <Button Classes="SettingsNav"
                            Command="{Binding SwitchSettingsSectionCommand}"
                            CommandParameter="歌词设置">
                        <TextBlock Text="歌词设置" Foreground="{DynamicResource SukiText}" />
                    </Button>

                    <Button Classes="SettingsNav"
                            Command="{Binding SwitchSettingsSectionCommand}"
                            CommandParameter="更新与关于">
                        <TextBlock Text="更新与关于" Foreground="{DynamicResource SukiText}" />
                    </Button>

                    <Button Classes="SettingsNav"
                            Command="{Binding SwitchSettingsSectionCommand}"
                            CommandParameter="账户">
                        <TextBlock Text="账户" Foreground="{DynamicResource SukiText}" />
                    </Button>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,0,24">
                <StackPanel Spacing="12" Margin="2,0,4,0">
                    <TextBlock Text="设置"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SukiText}" />

                    <suki:GlassCard IsOpaque="True" Padding="14" IsVisible="{Binding IsGeneralSection}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="常规"
                                       FontWeight="SemiBold"
                                       FontSize="16" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="主题模式" FontWeight="DemiBold" />
                                    <TextBlock Text="切换亮色/暗色主题"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              Classes="Gorgeous"
                                              IsChecked="{Binding IsDarkMode, Mode=TwoWay}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="关闭主面板时" FontWeight="DemiBold" />
                                    <TextBlock Text="选择点击关闭按钮时的行为"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          MinWidth="220"
                                          ItemsSource="{Binding AvailableCloseBehaviors}"
                                          SelectedItem="{Binding SelectedCloseBehavior}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="models:CloseBehavior">
                                            <TextBlock
                                                Text="{Binding Converter={StaticResource CloseBehaviorConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </suki:GlassCard>

                    <suki:GlassCard IsOpaque="True" Padding="14" IsVisible="{Binding IsPlaybackSection}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="播放与音效"
                                       FontWeight="SemiBold"
                                       FontSize="16" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="默认播放音质" FontWeight="DemiBold" />
                                    <TextBlock Text="音质从低到高"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          MinWidth="220"
                                          ItemsSource="{Binding Player.QualityOptions}"
                                          SelectedItem="{Binding Player.QualitySelection}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="x:String">
                                            <TextBlock
                                                Text="{Binding ., Converter={StaticResource PlaybackQualityDisplayConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <ComboBox.SelectionBoxItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Text="{Binding ., Converter={StaticResource PlaybackQualityDisplayConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.SelectionBoxItemTemplate>
                                </ComboBox>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="音效预设" FontWeight="DemiBold" />
                                    <TextBlock Text="选择预设风格或手动调节"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <Grid Grid.Column="1"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8"
                                      MinWidth="280">
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding EQPresetOptions}"
                                              SelectedItem="{Binding SelectedEQPreset}" />
                                    <Button Grid.Column="1"
                                            Classes="Basic"
                                            Cursor="Hand"
                                            Command="{Binding OpenEqSettingsCommand}"
                                            ToolTip.Tip="自定义EQ曲线">
                                        <Svg Path="/Assets/gear-svgrepo-com.svg" Width="18" Height="14" />
                                    </Button>
                                </Grid>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="智能过渡" FontWeight="DemiBold" />
                                    <TextBlock Text="自动预加载并在尾段平滑切到下一首"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding EnableSeamlessTransition, Mode=TwoWay}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="播放页音频可视化" FontWeight="DemiBold" />
                                    <TextBlock Text="控制播放页面进度条下方的频谱动画显示"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding EnableNowPlayingVisualizer, Mode=TwoWay}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="空间音效" FontWeight="DemiBold" />
                                    <TextBlock Text="3D音效，不保证好用"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding EnableSurround, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </suki:GlassCard>

                    <suki:GlassCard IsOpaque="True" Padding="14" IsVisible="{Binding IsShortcutsSection}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="快捷键"
                                       FontWeight="SemiBold"
                                       FontSize="16" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="启用全局快捷键" FontWeight="DemiBold" />
                                    <TextBlock Text="应用隐藏到托盘后也可触发播放控制与显示窗口"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding EnableGlobalShortcuts, Mode=TwoWay}" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ShortcutItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:GlobalShortcutItemViewModel">
                                        <Border BorderThickness="1"
                                                BorderBrush="{DynamicResource SukiBorder}"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,4,0,0">
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*,Auto,Auto"
                                                      ColumnSpacing="10">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="DemiBold" />
                                                        <TextBlock Text="{Binding ShortcutText}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource SukiLowText}" />
                                                    </StackPanel>

                                                    <Button Grid.Column="1"
                                                            Classes="Basic"
                                                            MinWidth="148"
                                                            Command="{Binding #UserRoot.((vm:UserViewModel)DataContext).BeginShortcutRecordingCommand}"
                                                            CommandParameter="{Binding .}"
                                                            behaviors:InteractionBehaviors.KeyDownCommand="{Binding #UserRoot.((vm:UserViewModel)DataContext).CaptureShortcutKeyCommand}"
                                                            behaviors:InteractionBehaviors.KeyDownCommandParameter="{Binding .}">
                                                        <TextBlock Text="{Binding ShortcutText}" />
                                                    </Button>

                                                    <Button Grid.Column="2"
                                                            Classes="Basic"
                                                            MinWidth="72"
                                                            Command="{Binding #UserRoot.((vm:UserViewModel)DataContext).ClearShortcutCommand}"
                                                            CommandParameter="{Binding .}">
                                                        <TextBlock Text="清空" />
                                                    </Button>
                                                </Grid>

                                                <TextBlock Text="{Binding StatusMessage}"
                                                           IsVisible="{Binding HasStatusMessage}"
                                                           FontSize="12"
                                                           Foreground="{Binding StatusForeground}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </suki:GlassCard>

                    <suki:GlassCard IsOpaque="True" Padding="14" IsVisible="{Binding IsLyricsSection}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="歌词设置"
                                       FontWeight="SemiBold"
                                       FontSize="16" />

                            <suki:GlassCard IsOpaque="True" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="桌面歌词"
                                               FontWeight="DemiBold"
                                               FontSize="15" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="启用旧版逐字歌词" FontWeight="DemiBold" />
                                            <TextBlock Text="使用逐词抬升与透明度变化效果"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      IsChecked="{Binding EnableLegacyWordLyricEffect, Mode=TwoWay}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="双行歌词" FontWeight="DemiBold" />
                                            <TextBlock Text="按奇偶行上下错开显示，开启后不显示翻译"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      IsChecked="{Binding DesktopLyricDoubleLineEnabled, Mode=TwoWay}" />
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource SukiBorder}" Margin="0,6" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="颜色应用目标" FontWeight="DemiBold" />
                                            <TextBlock Text="为歌词或翻译单独配置颜色"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="220"
                                                  ItemsSource="{Binding LyricColorTargetOptions}"
                                                  SelectedItem="{Binding DesktopSelectedLyricColorTarget}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="颜色模式" FontWeight="DemiBold" />
                                            <TextBlock Text="支持默认与自定义颜色"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="220"
                                                  ItemsSource="{Binding LyricColorModeOptions}"
                                                  SelectedItem="{Binding DesktopSelectedLyricColorMode}" />
                                    </Grid>

                                    <StackPanel IsVisible="{Binding IsDesktopLyricColorCustomMode}" Spacing="8"
                                                Margin="0,4,0,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0"
                                                    Width="28"
                                                    Height="28"
                                                    CornerRadius="14"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource SukiBorder}"
                                                    Background="{Binding DesktopLyricColorPreviewBrush}" />
                                            <TextBox Grid.Column="1"
                                                     Watermark="#FFFFFFFF"
                                                     Text="{Binding DesktopLyricColorHexInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="2"
                                                    Command="{Binding ApplyDesktopLyricColorHexCommand}"
                                                    Content="应用"
                                                    MinWidth="72" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding LyricColorPalette}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="8" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="x:String">
                                                    <Button Width="24"
                                                            Height="24"
                                                            Margin="3"
                                                            Padding="0"
                                                            CornerRadius="12"
                                                            Background="{Binding .}"
                                                            BorderThickness="1"
                                                            BorderBrush="{DynamicResource SukiBorder}"
                                                            Command="{Binding #UserRoot.((vm:UserViewModel)DataContext).PickDesktopLyricPaletteColorCommand}"
                                                            CommandParameter="{Binding .}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource SukiBorder}" Margin="0,6" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="字体模式" FontWeight="DemiBold" />
                                            <TextBlock Text="统一应用到歌词与翻译"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="220"
                                                  ItemsSource="{Binding LyricFontModeOptions}"
                                                  SelectedItem="{Binding DesktopSelectedLyricFontMode}" />
                                    </Grid>

                                    <StackPanel IsVisible="{Binding IsDesktopLyricFontCustomMode}" Spacing="8"
                                                Margin="0,4,0,0">
                                        <TextBlock Text="字体选择" FontWeight="DemiBold" />
                                        <ComboBox ItemsSource="{Binding LyricFontFamilyOptions}"
                                                  SelectedItem="{Binding DesktopSelectedLyricFontFamily}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="x:String">
                                                    <TextBlock Text="{Binding .}" FontFamily="{Binding .}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <Border BorderThickness="1"
                                                BorderBrush="{DynamicResource SukiBorder}"
                                                CornerRadius="8"
                                                Padding="10">
                                            <TextBlock Text="桌面歌词字体预览 Preview 123"
                                                       TextWrapping="Wrap"
                                                       FontFamily="{Binding DesktopSelectedLyricFontFamily}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </suki:GlassCard>

                            <suki:GlassCard IsOpaque="True" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="播放页面歌词"
                                               FontWeight="DemiBold"
                                               FontSize="15" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="颜色应用目标" FontWeight="DemiBold" />
                                            <TextBlock Text="为歌词或翻译单独配置颜色"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="220"
                                                  ItemsSource="{Binding LyricColorTargetOptions}"
                                                  SelectedItem="{Binding PlayPageSelectedLyricColorTarget}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="颜色模式" FontWeight="DemiBold" />
                                            <TextBlock Text="支持默认与自定义颜色"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="220"
                                                  ItemsSource="{Binding LyricColorModeOptions}"
                                                  SelectedItem="{Binding PlayPageSelectedLyricColorMode}" />
                                    </Grid>

                                    <StackPanel IsVisible="{Binding IsPlayPageLyricColorCustomMode}" Spacing="8"
                                                Margin="0,4,0,0">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0"
                                                    Width="28"
                                                    Height="28"
                                                    CornerRadius="14"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource SukiBorder}"
                                                    Background="{Binding PlayPageLyricColorPreviewBrush}" />
                                            <TextBox Grid.Column="1"
                                                     Watermark="#FFFFFFFF"
                                                     Text="{Binding PlayPageLyricColorHexInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="2"
                                                    Command="{Binding ApplyPlayPageLyricColorHexCommand}"
                                                    Content="应用"
                                                    MinWidth="72" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding LyricColorPalette}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="8" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="x:String">
                                                    <Button Width="24"
                                                            Height="24"
                                                            Margin="3"
                                                            Padding="0"
                                                            CornerRadius="12"
                                                            Background="{Binding .}"
                                                            BorderThickness="1"
                                                            BorderBrush="{DynamicResource SukiBorder}"
                                                            Command="{Binding #UserRoot.((vm:UserViewModel)DataContext).PickPlayPageLyricPaletteColorCommand}"
                                                            CommandParameter="{Binding .}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource SukiBorder}" Margin="0,6" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="字体模式" FontWeight="DemiBold" />
                                            <TextBlock Text="统一应用到歌词与翻译"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="220"
                                                  ItemsSource="{Binding LyricFontModeOptions}"
                                                  SelectedItem="{Binding PlayPageSelectedLyricFontMode}" />
                                    </Grid>

                                    <StackPanel IsVisible="{Binding IsPlayPageLyricFontCustomMode}" Spacing="8"
                                                Margin="0,4,0,0">
                                        <TextBlock Text="字体选择" FontWeight="DemiBold" />
                                        <ComboBox ItemsSource="{Binding LyricFontFamilyOptions}"
                                                  SelectedItem="{Binding PlayPageSelectedLyricFontFamily}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="x:String">
                                                    <TextBlock Text="{Binding .}" FontFamily="{Binding .}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <Border BorderThickness="1"
                                                BorderBrush="{DynamicResource SukiBorder}"
                                                CornerRadius="8"
                                                Padding="10">
                                            <TextBlock Text="播放页面歌词字体预览 Preview 123"
                                                       TextWrapping="Wrap"
                                                       FontFamily="{Binding PlayPageSelectedLyricFontFamily}" />
                                        </Border>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource SukiBorder}" Margin="0,6" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="歌词大小" FontWeight="DemiBold" />
                                            <TextBlock Text="调整播放页面歌词大小"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PlayPageLyricFontSizeDisplay}"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <Slider Minimum="18"
                                            Maximum="42"
                                            Value="{Binding PlayPageLyricFontSize, Mode=TwoWay}"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Margin="0,0,0,4" Classes="Player" />

                                    <Border Height="1" Background="{DynamicResource SukiBorder}" Margin="0,6" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                        <StackPanel>
                                            <TextBlock Text="歌词对齐" FontWeight="DemiBold" />
                                            <TextBlock Text="作用于播放页面滚动歌词"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SukiLowText}" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  MinWidth="220"
                                                  ItemsSource="{Binding LyricAlignmentOptions}"
                                                  SelectedItem="{Binding PlayPageSelectedLyricAlignment}" />
                                    </Grid>
                                </StackPanel>
                            </suki:GlassCard>
                        </StackPanel>
                    </suki:GlassCard>

                    <suki:GlassCard IsOpaque="True" Padding="14" IsVisible="{Binding IsUpdateSection}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="更新与关于"
                                       FontWeight="SemiBold"
                                       FontSize="16" />

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="14"
                                  Margin="0,4,0,2">
                                <Border Width="90"
                                        Height="90"
                                        CornerRadius="14"
                                        ClipToBounds="True"
                                        Background="{DynamicResource SukiPrimaryColorLow}">
                                    <Image Source="/Assets/Test.png"
                                           Width="90"
                                           Height="90"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="3">
                                    <TextBlock Text="{Binding AppDisplayName}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AppVersion}"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>

                                
                                <Button Classes="Basic" Grid.Column="2"
                                    Command="{Binding OpenRepositoryCommand}"
                                    Cursor="Hand"
                                    ToolTip.Tip="项目主页">
                                    <Svg Path="/Assets/github.svg" Width="25" Height="25"/>
                                </Button>
                                
                            </Grid>

                            <Border Height="1" Background="{DynamicResource SukiBorder}" Margin="0,2" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="自动检查更新" FontWeight="DemiBold" />
                                    <TextBlock Text="应用启动时自动检查新版本"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding AutoCheckUpdate, Mode=TwoWay}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="手动检查更新" FontWeight="DemiBold" />
                                    <TextBlock Text="立即检查并提示下载新版本"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="Basic"
                                        Command="{Binding CheckForUpdateCommand}"
                                        IsEnabled="{Binding !IsCheckingUpdate}"
                                        MinWidth="120">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="{x:Static suki:Icons.Refresh}" Width="16" Height="16" />
                                        <TextBlock Text="检查更新" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource SukiBorder}" Margin="0,2" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,4">
                                
                                <TextBlock Text="最近更新日志" FontWeight="DemiBold" />
                                
                                <Button Grid.Column="1"
                                        Classes="Basic"
                                        Command="{Binding RefreshReleaseNotesCommand}"
                                        IsEnabled="{Binding !IsLoadingReleaseNotes}"
                                        MinWidth="108">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="{x:Static suki:Icons.Refresh}" Width="16" Height="16" />
                                        <TextBlock Text="刷新" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Text="{Binding ReleaseNotesStatus}"
                                       IsVisible="{Binding IsReleaseNotesStatusVisible}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SukiLowText}"
                                       Margin="0,0,0,2" />

                            <ItemsControl ItemsSource="{Binding RecentReleaseNotes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ReleaseNoteItemViewModel">
                                        <Border BorderBrush="{DynamicResource SukiBorder}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,0,8"
                                                Background="{DynamicResource SukiBackground}">
                                            <StackPanel Spacing="6">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="DemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding PublishedAt}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SukiLowText}" />
                                                </Grid>
                                                
                                                <TextBlock Text="{Binding Summary}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12"
                                                           LineHeight="18"
                                                           Foreground="{DynamicResource SukiLowText}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </suki:GlassCard>

                    <suki:GlassCard IsOpaque="True" Padding="14" IsVisible="{Binding IsAccountSection}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="账户"
                                       FontWeight="SemiBold"
                                       FontSize="16" />

                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12"
                                  Margin="0,4,0,0">
                                <Border Width="56"
                                        Height="56"
                                        CornerRadius="28"
                                        ClipToBounds="True"
                                        Background="#E0E0E0">
                                    <controls:AsyncImage Source="{Binding UserAvatar}"
                                                         Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="2">
                                    <TextBlock Text="{Binding UserName}" FontWeight="DemiBold" />
                                    <TextBlock Text="{Binding VipStatus}"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                    <TextBlock Text="{Binding UserId, StringFormat='ID: {0}'}"
                                               FontSize="12"
                                               Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,6">
                                <StackPanel>
                                    <TextBlock Text="退出登录" FontWeight="DemiBold" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="Basic"
                                        Command="{Binding LogoutCommand}"
                                        MinWidth="120">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <PathIcon Data="{x:Static suki:Icons.Logout}" Width="16" Height="16" />
                                        <TextBlock Text="退出登录" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </suki:GlassCard>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </suki:GlassCard>
</UserControl>
