<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="KugouAvaloniaPlayer.Views.UserView"
             x:DataType="vm:UserViewModel">

    <suki:GlassCard Margin="40" Padding="30">
        <Grid RowDefinitions="Auto, *, Auto">
            <!-- 用户信息区域 -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,30">
                <!-- 头像 -->
                <Border Grid.Column="0"
                        Width="80" Height="80"
                        CornerRadius="40"
                        ClipToBounds="True"
                        Background="#E0E0E0">
                    <controls:AsyncImage Source="{Binding UserAvatar}"
                                         Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="{Binding UserName}"
                               FontSize="24"
                               FontWeight="Bold" Foreground="{DynamicResource SukiLowText}" />
                    <TextBlock Text="{Binding VipStatus}"
                               FontSize="14"
                               Foreground="{DynamicResource SukiLiquid2}"
                               Margin="0,5,0,0" />
                    <TextBlock Text="{Binding UserId, StringFormat='ID: {0}'}"
                               FontSize="12"
                               Foreground="{DynamicResource SukiLiquid2}"
                               Margin="0,3,0,0" />
                    <ToggleSwitch Classes="Gorgeous"
                                  IsChecked="{Binding IsDarkMode, Mode=TwoWay}" HorizontalAlignment="Right" Width="150"
                                  VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Margin="30,0,30,20">
                <StackPanel Spacing="20">

                    <TextBlock Text="通用设置" FontWeight="Bold" FontSize="18" Margin="0,0,0,5" />

                    <!-- 关闭行为设置 -->
                    <suki:GlassCard IsOpaque="True" Padding="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel>
                                <TextBlock Text="关闭主面板时" FontWeight="DemiBold" />
                                <TextBlock Text="选择点击关闭按钮时的行为" FontSize="12" Foreground="{DynamicResource SukiLiquid2}" />
                            </StackPanel>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableCloseBehaviors}"
                                      SelectedItem="{Binding SelectedCloseBehavior}"
                                      MinWidth="150">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource CloseBehaviorConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </suki:GlassCard>

                    <!-- 音质选择 -->
                    <suki:GlassCard IsOpaque="True" Padding="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel>
                                <TextBlock Text="默认播放音质" FontWeight="DemiBold" />
                                <TextBlock Text="音质从低到高" FontSize="12" Foreground="{DynamicResource SukiLiquid2}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding QualityOptions}"
                                      SelectedItem="{Binding SelectedQuality}"
                                      MinWidth="150" />
                        </Grid>
                    </suki:GlassCard>
                    
                    <suki:GlassCard IsOpaque="True" Padding="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel>
                                <TextBlock Text="音效" FontWeight="DemiBold" />
                                <TextBlock Text="选择预设的风格，实时生效(不保证好用)" FontSize="12" Foreground="{DynamicResource SukiLiquid2}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding EQPresetOptions}"
                                      SelectedItem="{Binding SelectedEQPreset}"
                                      MinWidth="150" />
                        </Grid>
                    </suki:GlassCard>

                    <!-- 全景声 / 空间音效 -->
                    <suki:GlassCard IsOpaque="True" Padding="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel>
                                <TextBlock Text="空间音效" FontWeight="DemiBold" />
                                <TextBlock Text="没想好具体怎么做，目前会很电，不建议使用(我不会告诉你任何事情的啊啊啊啊)" FontSize="12" Foreground="{DynamicResource SukiLiquid2}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EnableSurround, Mode=TwoWay}" />
                        </Grid>
                    </suki:GlassCard>

                    <!-- 自动检查更新 -->
                    <suki:GlassCard IsOpaque="True" Padding="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel>
                                <TextBlock Text="启动时自动检查更新" FontWeight="DemiBold" />
                                <TextBlock Text="每次启动应用时检查是否有新版本" FontSize="12"
                                           Foreground="{DynamicResource SukiLiquid2}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding AutoCheckUpdate, Mode=TwoWay}" />
                        </Grid>
                    </suki:GlassCard>

                    <!-- 手动检查更新 -->
                    <suki:GlassCard IsOpaque="True" Padding="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel>
                                <TextBlock Text="检查更新" FontWeight="DemiBold" />
                                <TextBlock Text="手动检查是否有新版本可用" FontSize="12" Foreground="{DynamicResource SukiLiquid2}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="Basic"
                                    Command="{Binding CheckForUpdateCommand}"
                                    IsEnabled="{Binding !IsCheckingUpdate}"
                                    MinWidth="120">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{x:Static suki:Icons.Refresh}"
                                              Width="16" Height="16" Foreground="{DynamicResource SukiLowText}" />
                                    <TextBlock Text="检查更新" Foreground="{DynamicResource SukiLowText}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </suki:GlassCard>
                </StackPanel>
            </ScrollViewer>

            <!-- 退出登录按钮 -->
            <Button Grid.Row="2"
                    Classes="Basic"
                    Command="{Binding LogoutCommand}"
                    HorizontalAlignment="Right"
                    Foreground="{DynamicResource SukiLowText}"
                    Padding="30,10"
                    Margin="0,0,0,50"
                    ToolTip.Tip="退出登录">
                <PathIcon Data="{x:Static suki:Icons.Logout}" />
            </Button>
        </Grid>
    </suki:GlassCard>
</UserControl>