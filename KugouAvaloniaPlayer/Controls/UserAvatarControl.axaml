<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             x:Class="KugouAvaloniaPlayer.Controls.UserAvatarControl"
             x:DataType="vm:MainWindowViewModel">

    <Panel>
        <!-- 未登录状态 -->
        <Button Classes="Basic"
                Cursor="Hand"
                Command="{Binding ShowLoginDialogCommand}"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding !IsLoggedIn}">
            <TextBlock Text="点击登录" Foreground="{DynamicResource SukiLowText}" />
        </Button>

        <!-- 已登录状态 -->
        <Border IsVisible="{Binding IsLoggedIn}"
                Padding="8"
                Background="Transparent">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <Border Width="60"
                        Height="60"
                        CornerRadius="26"
                        ClipToBounds="True"
                        Background="#E0E0E0">
                    <controls:AsyncImage Source="{Binding UserAvatar}"
                                         Stretch="UniformToFill" />
                </Border>
                <TextBlock Text="{Binding UserName}"
                           MaxWidth="130"
                           TextTrimming="CharacterEllipsis"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource SukiText}" />
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
