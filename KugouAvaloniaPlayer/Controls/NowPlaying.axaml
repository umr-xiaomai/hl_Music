<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:controls1="clr-namespace:KugouAvaloniaPlayer.Controls"
             x:Class="KugouAvaloniaPlayer.Controls.NowPlaying"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="Grid#Root">
            <Setter Property="IsVisible" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(200px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Grid#Root.open">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0)" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,15" /> <!-- 增加行间距 -->
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Content="{TemplateBinding Content}"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TextBlock.NowPlayingLine">
            <Setter Property="FontSize" Value="26" />
        </Style>

        <Style Selector="TextBlock.NowPlayingWord">
            <Setter Property="FontSize" Value="26" />
        </Style>

        <Style Selector="TextBlock.NowPlayingTrans">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style Selector="Slider.NowPlayingVolume">
            <Setter Property="Background" Value="#40FFFFFF" />
            <Setter Property="Foreground" Value="#F2FFFFFF" />
            <Setter Property="MinHeight" Value="24" />
        </Style>

        <Style Selector="Slider.NowPlayingVolume:pointerover /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Opacity" Value="1" />
        </Style>

    </UserControl.Styles>

    <Grid Name="Root"
          Classes.open="{Binding IsNowPlayingOpen}"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          ClipToBounds="True">
        <Panel>
            <Border Background="#FF000000" />
            <controls:AsyncImage Source="{Binding Player.CurrentPlayingSong.Cover}"
                                 Stretch="UniformToFill"
                                 RenderTransformOrigin="0.5,0.5"
                                 RenderTransform="scale(1.12)">
                <controls:AsyncImage.Effect>
                    <BlurEffect Radius="100" />
                </controls:AsyncImage.Effect>
            </controls:AsyncImage>
            <Border Background="#50000000" />
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#20000000" Offset="0" />
                        <GradientStop Color="#80000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Panel>
        <Grid RowDefinitions="Auto, *" Margin="40">
            <Button Grid.Row="0" Cursor="Hand"
                    Command="{Binding CloseNowPlayingCommand}"
                    Classes="Basic" HorizontalAlignment="Left" Margin="0,10,0,0">
                <Border Background="#30FFFFFF" CornerRadius="20" Padding="15,8">
                    <PathIcon Data="{x:Static suki:Icons.ChevronDown}" Foreground="White" Width="15" Height="15" />
                </Border>
            </Button>

            <Grid Grid.Row="1" ColumnDefinitions="4*, 6*" Margin="0,30,0,50">

                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="40">
                    <suki:GlassCard CornerRadius="20" Padding="0" Width="350" Height="350">
                        <controls:AsyncImage Source="{Binding Player.CurrentPlayingSong.Cover}" Stretch="UniformToFill" />
                    </suki:GlassCard>

                    <StackPanel Spacing="10" HorizontalAlignment="Left" Margin="10,0">
                        <TextBlock Text="{Binding Player.CurrentPlayingSong.Name}"
                                   FontSize="28" FontWeight="Bold" Foreground="White"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Player.CurrentPlayingSong.Singer}"
                                   FontSize="18" Foreground="#DDFFFFFF"
                                   TextTrimming="CharacterEllipsis" />
                        <Grid RowDefinitions="Auto, Auto, Auto" VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="25" HorizontalAlignment="Center">
                                <Button Cursor="Hand"
                                        Command="{Binding ToggleNowPlayingVolumeCommand}"
                                        Classes="Basic">
                                    <Svg Path="/Assets/VolumeUp.svg"
                                         Css="path { fill: white; }"
                                         Width="20"
                                         Height="20"
                                         Opacity="0.85" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.ToggleShuffleModeCommand}"
                                        Classes="Basic">
                                    <StackPanel>
                                        <Svg Path="/Assets/shuffle-svgrepo-com.svg" Css="path { fill: white; }"
                                             Width="20" Height="20" IsVisible="{Binding Player.IsShuffleMode}" />
                                        <Svg Path="/Assets/repeat-svgrepo-com.svg" Css="path { fill: white; }"
                                             Width="20" Height="20" IsVisible="{Binding !Player.IsShuffleMode}" />
                                    </StackPanel>
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.PlayPreviousCommand}" Classes="Basic"
                                        ToolTip.Tip="上一首">
                                    <Svg Path="/Assets/backward.svg" Css="path { fill: white; }" Width="18" Height="18" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.TogglePlayPauseCommand}" Classes="Basic"
                                        Width="36"
                                        Height="36">
                                    <Panel>
                                        <Svg Path="/Assets/pause-1006-svgrepo-com.svg" Width="24" Height="24"
                                             Css="path { fill: white; }"
                                             IsVisible="{Binding Player.IsPlayingAudio}" />
                                        <Svg Path="/Assets/play-1003-svgrepo-com.svg" Width="24" Height="24"
                                             Css="path { fill: white; }"
                                             IsVisible="{Binding !Player.IsPlayingAudio}" />
                                    </Panel>
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.PlayNextCommand}" Classes="Basic"
                                        ToolTip.Tip="下一首">
                                    <Svg Path="/Assets/next-svgrepo-com.svg" Css="path { fill: white; }" Width="18"
                                         Height="18" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.ToggleLikeCommand}"
                                        Classes="Basic"
                                        ToolTip.Tip="添加到我喜欢">
                                    <Panel>
                                        <Svg Path="/Assets/FavoriteBorder.svg" Css="path { fill: red; }"
                                             Width="20" Height="20"
                                             IsVisible="{Binding Player.IsLiked}" />

                                        <Svg Path="/Assets/FavoriteBorder.svg" Css="path { fill: white; }"
                                             Opacity="0.6"
                                             Width="20" Height="20"
                                             IsVisible="{Binding !Player.IsLiked}" />
                                    </Panel>
                                </Button>
                            </StackPanel>

                            <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Width="400" Margin="0,4,0,0">
                                <Slider Grid.Column="1" Minimum="0" Maximum="{Binding Player.TotalDurationSeconds}"
                                        Value="{Binding Player.CurrentPositionSeconds}"
                                        Margin="8,0" IsSnapToTickEnabled="False"
                                        HorizontalAlignment="Stretch"
                                        Classes="Player" />
                            </Grid>

                            <Grid Grid.Row="2"
                                  ColumnDefinitions="Auto, *, Auto"
                                  Width="240"
                                  Margin="0,10,0,0"
                                  HorizontalAlignment="Center"
                                  IsVisible="{Binding IsNowPlayingVolumeVisible}">
                                <Svg Path="/Assets/VolumeOff.svg"
                                     Css="path { fill: white; }"
                                     Width="25"
                                     Height="25"
                                     Opacity="0.78"
                                     VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding Player.MusicVolume}"
                                        Margin="10,0"
                                        Classes="Player NowPlayingVolume"
                                        HorizontalAlignment="Stretch"/>
                                <Svg Grid.Column="2"
                                     Path="/Assets/VolumeUp.svg"
                                     Css="path { fill: white; }"
                                     Width="25"
                                     Height="25"
                                     Opacity="0.9"
                                     VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <controls1:MeasuredLyricScrollView x:Name="LyricScrollView"
                                                   Grid.Column="1"
                                                   ItemsSource="{Binding Player.LyricLines}"
                                                   ActiveItem="{Binding Player.CurrentLyricLine}"
                                                   ScrollDuration="0:0:0.37"
                                                   LineSpacing="22"
                                                   Margin="60,0,0,0">
                    <controls1:MeasuredLyricScrollView.ItemTemplate>
                        <DataTemplate DataType="vm:LyricLineViewModel">
                            <StackPanel Margin="0,15">
                                <TextBlock Text="{Binding Content}"
                                           Classes="KaraokeLine NowPlayingLine"
                                           Classes.active="{Binding IsActive}"
                                           IsVisible="{Binding IsKrcWordLevel, Converter={x:Static BoolConverters.Not}}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center" TextAlignment="Center" />
                                <ItemsControl ItemsSource="{Binding Words}"
                                              IsVisible="{Binding IsKrcWordLevel}"
                                              HorizontalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:LyricWordViewModel">
                                            <TextBlock Text="{Binding Text}"
                                                       Classes="KaraokeWord NowPlayingWord"
                                                       Classes.played="{Binding IsPlayed}"
                                                       Classes.current="{Binding IsCurrent}"
                                                       RenderTransform="{Binding LiftOffset, Converter={StaticResource WordLiftTransformConverter}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding Translation}"
                                           Classes="KaraokeTrans NowPlayingTrans"
                                           Classes.active="{Binding IsActive}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center" TextAlignment="Center">
                                    <TextBlock.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="Translation"
                                                     Converter="{x:Static StringConverters.IsNotNullOrEmpty}" />
                                            <Binding Path="HasWordLevelTranslation"
                                                     Converter="{x:Static BoolConverters.Not}" />
                                        </MultiBinding>
                                    </TextBlock.IsVisible>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding TranslationWords}"
                                              IsVisible="{Binding HasWordLevelTranslation}"
                                              HorizontalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:LyricWordViewModel">
                                            <TextBlock Text="{Binding Text}"
                                                       Classes="KaraokeTransWord NowPlayingTrans"
                                                       Classes.played="{Binding IsPlayed}"
                                                       Classes.current="{Binding IsCurrent}"
                                                       RenderTransform="{Binding LiftOffset, Converter={StaticResource WordLiftTransformConverter}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </controls1:MeasuredLyricScrollView.ItemTemplate>
                </controls1:MeasuredLyricScrollView>

                <TextBlock Grid.Column="1" Text="暂无歌词"
                           IsVisible="{Binding !Player.LyricLines.Count}"
                           Foreground="White" Opacity="0.5" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
