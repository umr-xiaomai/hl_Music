<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:controls1="clr-namespace:KugouAvaloniaPlayer.Controls"
             x:Class="KugouAvaloniaPlayer.Controls.NowPlaying"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="Grid#Root">
            <Setter Property="IsVisible" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(200px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseOut" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Grid#Root.open">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0)" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,15" /> <!-- 增加行间距 -->
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Background="Transparent"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Content="{TemplateBinding Content}"
                                      Padding="{TemplateBinding Padding}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TextBlock.NowPlayingLine">
            <Setter Property="FontSize"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricFontSize}" />
            <Setter Property="FontFamily"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricFontFamily}" />
            <Setter Property="Foreground"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricForeground}" />
        </Style>

        <Style Selector="TextBlock.NowPlayingWord">
            <Setter Property="FontSize"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricFontSize}" />
            <Setter Property="FontFamily"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricFontFamily}" />
            <Setter Property="Foreground"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricForeground}" />
        </Style>

        <Style Selector="TextBlock.NowPlayingTrans">
            <Setter Property="FontSize"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingTranslationFontSize}" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="FontFamily"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricFontFamily}" />
            <Setter Property="Foreground"
                    Value="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingTranslationLineForeground}" />
        </Style>

        <Style Selector="Slider.NowPlayingSlider">
            <Setter Property="Background" Value="#40FFFFFF" />
            <Setter Property="Foreground" Value="#F2FFFFFF" />
        </Style>

        <Style Selector="Slider.NowPlayingSlider /template/ Thumb#thumb">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#F2FFFFFF" />
        </Style>

        <Style Selector="Slider.NowPlayingSlider:pointerover /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Slider.NowPlayingVolume">
            <Setter Property="Background" Value="#40FFFFFF" />
            <Setter Property="Foreground" Value="#F2FFFFFF" />
            <Setter Property="MinHeight" Value="24" />
        </Style>

        <Style Selector="Slider.NowPlayingVolume:pointerover /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Border.VisualizerBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
                    <GradientStop Color="#22FFFFFF" Offset="0" />
                    <GradientStop Color="#9A22D3EE" Offset="0.36" />
                    <GradientStop Color="#E8FFFFFF" Offset="0.7" />
                    <GradientStop Color="#CFF472B6" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BoxShadow" Value="0 0 36 0 #8022D3EE" />
        </Style>

        <Style Selector="StackPanel#AlbumMotionContainer">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="controls1|MeasuredLyricScrollView#LyricScrollView">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.32" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

    </UserControl.Styles>

    <Grid Name="Root"
          Classes.open="{Binding IsNowPlayingOpen}"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          ClipToBounds="True">
        <Panel>
            <controls:AsyncImage Source="{Binding Player.PreparedNextCover}"
                                 Width="1"
                                 Height="1"
                                 Opacity="0"
                                 IsHitTestVisible="False"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top" />
            <Border Background="#FF000000" />
            <controls:AsyncImage Source="{Binding Player.DisplayedPlayingSong.Cover}"
                                 Stretch="UniformToFill"
                                 RenderTransformOrigin="0.5,0.5"
                                 RenderTransform="scale(1.12)">
                <controls:AsyncImage.Effect>
                    <BlurEffect Radius="180" />
                </controls:AsyncImage.Effect>
            </controls:AsyncImage>

            <Grid IsHitTestVisible="False"
                  IsVisible="{Binding Player.IsNowPlayingVisualizerEnabled}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  RowDefinitions="*,Auto"
                  Opacity="0.96">
                <ItemsControl Grid.Row="1"
                              Height="320"
                              Margin="-80,0,-80,-28"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Bottom"
                              ItemsSource="{Binding Player.NowPlayingVisualizerBars}">
                    <ItemsControl.Effect>
                        <BlurEffect Radius="1.6" />
                    </ItemsControl.Effect>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:AudioVisualizerBarViewModel">
                            <Border Classes="VisualizerBar"
                                    Height="{Binding Height}"
                                    Opacity="{Binding Opacity}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Border Background="#50000000" />
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#24000000" Offset="0" />
                        <GradientStop Color="#64000000" Offset="0.48" />
                        <GradientStop Color="#90000000" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Panel>
        <Grid RowDefinitions="Auto, *" Margin="40">
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0">
                <Button Cursor="Hand"
                        Command="{Binding CloseNowPlayingCommand}"
                        Classes="Basic">
                    <Border Background="#30FFFFFF" CornerRadius="20" Padding="15,8">
                        <PathIcon Data="{x:Static suki:Icons.ChevronDown}" Foreground="White" Width="15" Height="15" />
                    </Border>
                </Button>

                <Button Cursor="Hand"
                        Command="{Binding ToggleNowPlayingLyricDisplayModeCommand}"
                        Classes="Basic">
                    <Border Background="#30FFFFFF" CornerRadius="20" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Svg Path="/Assets/translation-svgrepo-com.svg"
                                 Css="path { fill: white; }"
                                 Width="25"                                                                                                                                                                                 
                                 Height="25"
                                 Opacity="0.9" />
                        </StackPanel>
                    </Border>
                </Button>
            </StackPanel>

            <Grid Grid.Row="1" ColumnDefinitions="4*, 6*" Margin="0,30,0,28">

                <StackPanel Grid.Column="0"
                            x:Name="AlbumMotionContainer"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="40"
                            Opacity="{Binding Player.NowPlayingArtworkOpacity}">
                    <StackPanel.RenderTransform>
                        <TranslateTransform Y="{Binding Player.NowPlayingArtworkTranslateY}">
                            <TranslateTransform.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Y" Duration="0:0:0.28" Easing="CubicEaseOut" />
                                </Transitions>
                            </TranslateTransform.Transitions>
                        </TranslateTransform>
                    </StackPanel.RenderTransform>
                    <suki:GlassCard CornerRadius="20" Padding="0" Width="320" Height="320" MinWidth="220"
                                    MinHeight="220" MaxWidth="350" MaxHeight="350">
                        <controls:AsyncImage Source="{Binding Player.DisplayedPlayingSong.Cover}" Stretch="UniformToFill" />
                    </suki:GlassCard>

                    <StackPanel Spacing="10" HorizontalAlignment="Left" Margin="10,0">
                        <TextBlock Text="{Binding Player.DisplayedPlayingSong.Name}"
                                   FontSize="28" FontWeight="Bold" Foreground="White"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Player.DisplayedPlayingSong.Singer}"
                                   FontSize="18" Foreground="#DDFFFFFF"
                                   TextTrimming="CharacterEllipsis" />
                        <Grid RowDefinitions="Auto, Auto, Auto" VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="25" HorizontalAlignment="Center">
                                <Button Cursor="Hand"
                                        Command="{Binding ToggleNowPlayingVolumeCommand}"
                                        Classes="Basic">
                                    <Svg Path="/Assets/VolumeUp.svg"
                                         Css="path { fill: white; }"
                                         Width="20"
                                         Height="20"
                                         Opacity="0.85" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.ToggleShuffleModeCommand}"
                                        Classes="Basic">
                                    <StackPanel>
                                        <Svg Path="/Assets/shuffle-svgrepo-com.svg" Css="path { fill: white; }"
                                             Width="20" Height="20" IsVisible="{Binding Player.IsShuffleMode}" />
                                        <Svg Path="/Assets/repeat-svgrepo-com.svg" Css="path { fill: white; }"
                                             Width="20" Height="20" IsVisible="{Binding !Player.IsShuffleMode}" />
                                    </StackPanel>
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.PlayPreviousCommand}" Classes="Basic"
                                        ToolTip.Tip="上一首">
                                    <Svg Path="/Assets/backward.svg" Css="path { fill: white; }" Width="18" Height="18" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.TogglePlayPauseCommand}" Classes="Basic"
                                        Width="36"
                                        Height="36">
                                    <Panel>
                                        <Svg Path="/Assets/pause-1006-svgrepo-com.svg" Width="24" Height="24"
                                             Css="path { fill: white; }"
                                             IsVisible="{Binding Player.IsPlayingAudio}" />
                                        <Svg Path="/Assets/play-1003-svgrepo-com.svg" Width="24" Height="24"
                                             Css="path { fill: white; }"
                                             IsVisible="{Binding !Player.IsPlayingAudio}" />
                                    </Panel>
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.PlayNextCommand}" Classes="Basic"
                                        ToolTip.Tip="下一首">
                                    <Svg Path="/Assets/next-svgrepo-com.svg" Css="path { fill: white; }" Width="18"
                                         Height="18" />
                                </Button>
                                <Button Cursor="Hand" Command="{Binding Player.ToggleLikeCommand}"
                                        Classes="Basic"
                                        ToolTip.Tip="添加到我喜欢">
                                    <Panel>
                                        <Svg Path="/Assets/FavoriteBorder.svg" Css="path { fill: red; }"
                                             Width="20" Height="20"
                                             IsVisible="{Binding Player.IsLiked}" />

                                        <Svg Path="/Assets/FavoriteBorder.svg" Css="path { fill: white; }"
                                             Opacity="0.6"
                                             Width="20" Height="20"
                                             IsVisible="{Binding !Player.IsLiked}" />
                                    </Panel>
                                </Button>
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  MinWidth="220"
                                  MaxWidth="420"
                                  Margin="0,4,0,0"
                                  HorizontalAlignment="Stretch">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Slider Grid.Column="1" Minimum="0" Maximum="{Binding Player.TotalDurationSeconds}"
                                            Value="{Binding Player.CurrentPositionSeconds}"
                                            Margin="8,0" IsSnapToTickEnabled="False"
                                            HorizontalAlignment="Stretch"
                                            Classes="Player NowPlayingSlider" />
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="2"
                                  ColumnDefinitions="Auto, *, Auto"
                                  MinWidth="220"
                                  MaxWidth="420"
                                  Margin="0,10,0,0"
                                  HorizontalAlignment="Center"
                                  IsVisible="{Binding IsNowPlayingVolumeVisible}">
                                <Svg Path="/Assets/VolumeOff.svg"
                                     Css="path { fill: white; }"
                                     Width="25"
                                     Height="25"
                                     Opacity="0.78"
                                     VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding Player.MusicVolume}"
                                        Margin="10,0"
                                        Classes="Player NowPlayingVolume"
                                        HorizontalAlignment="Stretch" />
                                <Svg Grid.Column="2"
                                     Path="/Assets/VolumeUp.svg"
                                     Css="path { fill: white; }"
                                     Width="25"
                                     Height="25"
                                     Opacity="0.9"
                                     VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <controls1:MeasuredLyricScrollView x:Name="LyricScrollView"
                                                   Grid.Column="1"
                                                   ItemsSource="{Binding Player.LyricLines}"
                                                   ActiveItem="{Binding Player.CurrentLyricLine}"
                                                   ActiveAnchorRatio="0.34"
                                                   ScrollDuration="0:0:0.37"
                                                   LineSpacing="22"
                                                   Margin="60,0,0,0"
                                                   Opacity="{Binding Player.NowPlayingLyricsOpacity}">
                    <controls1:MeasuredLyricScrollView.RenderTransform>
                        <TranslateTransform Y="{Binding Player.NowPlayingLyricsTranslateY}">
                            <TranslateTransform.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Y" Duration="0:0:0.32" Easing="CubicEaseOut" />
                                </Transitions>
                            </TranslateTransform.Transitions>
                        </TranslateTransform>
                    </controls1:MeasuredLyricScrollView.RenderTransform>
                    <controls1:MeasuredLyricScrollView.ItemTemplate>
                        <DataTemplate DataType="vm:LyricLineViewModel">
                            <Grid Margin="0,15"
                                  Width="{Binding $parent[controls1:MeasuredLyricScrollView].Bounds.Width}">
                                <StackPanel HorizontalAlignment="Stretch">
                                    <TextBlock Text="{Binding Content}"
                                               Classes="KaraokeLine NowPlayingLine"
                                               Classes.active="{Binding IsActive}"
                                               Width="{Binding $parent[controls1:MeasuredLyricScrollView].Bounds.Width}"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Stretch"
                                               TextAlignment="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricTextAlignment}">
                                        <TextBlock.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="IsKrcWordLevel"
                                                         Converter="{x:Static BoolConverters.Not}" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).IsNowPlayingPrimaryLyricVisible" />
                                            </MultiBinding>
                                        </TextBlock.IsVisible>
                                    </TextBlock>

                                    <Grid Width="{Binding $parent[controls1:MeasuredLyricScrollView].Bounds.Width}">
                                        <Grid.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="IsKrcWordLevel" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).IsNowPlayingPrimaryLyricVisible" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).EnableLegacyWordLyricEffect" />
                                            </MultiBinding>
                                        </Grid.IsVisible>
                                        <ItemsControl ItemsSource="{Binding Words}"
                                                      HorizontalAlignment="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricHorizontalAlignment}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:LyricWordViewModel">
                                                    <TextBlock Text="{Binding Text}"
                                                               Classes="KaraokeWord NowPlayingWord"
                                                               Classes.played="{Binding IsPlayed}"
                                                               Classes.current="{Binding IsCurrent}"
                                                               RenderTransform="{Binding LiftOffset, Converter={StaticResource WordLiftTransformConverter}}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <Grid Width="{Binding $parent[controls1:MeasuredLyricScrollView].Bounds.Width}">
                                        <Grid.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="IsKrcWordLevel" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).IsNowPlayingPrimaryLyricVisible" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).EnableLegacyWordLyricEffect"
                                                    Converter="{x:Static BoolConverters.Not}" />
                                            </MultiBinding>
                                        </Grid.IsVisible>
                                        <ItemsControl ItemsSource="{Binding Words}"
                                                      HorizontalAlignment="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricHorizontalAlignment}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:LyricWordViewModel">
                                                    <controls1:KaraokeGradientTextBlock Text="{Binding Text}"
                                                                                       Progress="{Binding Progress}"
                                                                                       FontSize="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricFontSize}"
                                                                                       FontFamily="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricFontFamily}"
                                                                                       FontWeight="Bold"
                                                                                       Foreground="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricForeground}"
                                                                                       PlayedForeground="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricForeground}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <TextBlock Text="{Binding Translation}"
                                               Classes="KaraokeTrans NowPlayingTrans"
                                               Classes.active="{Binding IsActive}"
                                               Width="{Binding $parent[controls1:MeasuredLyricScrollView].Bounds.Width}"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Stretch"
                                               TextAlignment="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricTextAlignment}">
                                        <TextBlock.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="Translation"
                                                         Converter="{x:Static StringConverters.IsNotNullOrEmpty}" />
                                                <Binding Path="HasWordLevelTranslation"
                                                         Converter="{x:Static BoolConverters.Not}" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).IsNowPlayingTranslationVisible" />
                                            </MultiBinding>
                                        </TextBlock.IsVisible>
                                    </TextBlock>

                                    <Grid Width="{Binding $parent[controls1:MeasuredLyricScrollView].Bounds.Width}">
                                        <Grid.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="HasWordLevelTranslation" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).IsNowPlayingTranslationVisible" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).EnableLegacyWordLyricEffect" />
                                            </MultiBinding>
                                        </Grid.IsVisible>
                                        <ItemsControl ItemsSource="{Binding TranslationWords}"
                                                      HorizontalAlignment="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricHorizontalAlignment}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:LyricWordViewModel">
                                                    <TextBlock Text="{Binding Text}"
                                                               Classes="KaraokeTransWord NowPlayingTrans"
                                                               Classes.played="{Binding IsPlayed}"
                                                               Classes.current="{Binding IsCurrent}"
                                                               Foreground="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingTranslationWordForeground}"
                                                               RenderTransform="{Binding LiftOffset, Converter={StaticResource WordLiftTransformConverter}}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <Grid Width="{Binding $parent[controls1:MeasuredLyricScrollView].Bounds.Width}">
                                        <Grid.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="HasWordLevelTranslation" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).IsNowPlayingTranslationVisible" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).EnableLegacyWordLyricEffect"
                                                    Converter="{x:Static BoolConverters.Not}" />
                                            </MultiBinding>
                                        </Grid.IsVisible>
                                        <ItemsControl ItemsSource="{Binding TranslationWords}"
                                                      HorizontalAlignment="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricHorizontalAlignment}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:LyricWordViewModel">
                                                    <controls1:KaraokeGradientTextBlock Text="{Binding Text}"
                                                                                       Progress="{Binding Progress}"
                                                                                       FontSize="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingTranslationFontSize}"
                                                                                       FontFamily="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricFontFamily}"
                                                                                       FontWeight="Medium"
                                                                                       Foreground="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingTranslationWordForeground}"
                                                                                       PlayedForeground="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingTranslationWordForeground}"
                                                                                       UnplayedOpacity="0.4" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <TextBlock Text="{Binding Romanization}"
                                               Classes="KaraokeTrans NowPlayingTrans"
                                               Classes.active="{Binding IsActive}"
                                               Width="{Binding $parent[controls1:MeasuredLyricScrollView].Bounds.Width}"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Stretch"
                                               TextAlignment="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).NowPlayingLyricTextAlignment}">
                                        <TextBlock.IsVisible>
                                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                <Binding Path="Romanization"
                                                         Converter="{x:Static StringConverters.IsNotNullOrEmpty}" />
                                                <Binding
                                                    Path="$parent[UserControl].((vm:MainWindowViewModel)DataContext).IsNowPlayingRomanizationVisible" />
                                            </MultiBinding>
                                        </TextBlock.IsVisible>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </controls1:MeasuredLyricScrollView.ItemTemplate>
                </controls1:MeasuredLyricScrollView>

                <TextBlock Grid.Column="1" Text="暂无歌词"
                           IsVisible="{Binding !Player.LyricLines.Count}"
                           Foreground="White" Opacity="0.5" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>

        </Grid>
    </Grid>
</UserControl>
