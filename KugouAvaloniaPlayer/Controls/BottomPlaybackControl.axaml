<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             x:Class="KugouAvaloniaPlayer.Controls.BottomPlaybackControl"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="suki|GlassCard#MiniPlayer">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="suki|GlassCard#MiniPlayer.hidden">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="ComboBox.QualityCombo">
            <Setter Property="MinWidth" Value="96" />
        </Style>
        <Style Selector="ComboBox.QualityCombo ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <suki:GlassCard Name="MiniPlayer"
                        VerticalAlignment="Bottom"
                        Margin="20,0,20,16"
                        Padding="16,0"
                        CornerRadius="18"
                        Classes.hidden="{Binding IsNowPlayingOpen}"
                        Height="72"
                        IsOpaque="True">

            <Grid ColumnDefinitions="*, Auto, *">

                <!-- 左侧：封面 + 歌曲信息 -->
                <Button Grid.Column="0"
                        Command="{Binding OpenNowPlayingCommand}"
                        Classes="Basic"
                        Padding="0"
                        Cursor="Hand"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto, Auto">
                        <Border CornerRadius="10"
                                ClipToBounds="True"
                                Width="48"
                                Height="48">
                            <controls:AsyncImage Source="{Binding Player.DisplayedPlayingSong.Cover}"
                                                 Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    Spacing="4">
                            <TextBlock Text="{Binding Player.DisplayedPlayingSong.Name, TargetNullValue='KA Music'}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       MaxWidth="200"
                                       Foreground="{DynamicResource SukiText}" />
                            <TextBlock Text="{Binding Player.DisplayedPlayingSong.Singer, TargetNullValue='Ready'}"
                                       FontSize="11"
                                       Opacity="0.55"
                                       MaxWidth="200"
                                       Foreground="{DynamicResource SukiLowText}" />
                        </StackPanel>
                    </Grid>
                </Button>

                <!-- 中间：播放控制 + 进度条 -->
                <Grid Grid.Column="1"
                      RowDefinitions="Auto, Auto"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center">

                    <!-- 播放按钮组 -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,10,0,-15">
                        <Button Cursor="Hand"
                                Command="{Binding Player.PlayPreviousCommand}"
                                Classes="Basic"
                                ToolTip.Tip="上一首"
                                Width="32" Height="32">
                            <Svg Path="/Assets/backward.svg" Width="16" Height="16" />
                        </Button>
                        <Button Cursor="Hand"
                                Command="{Binding Player.TogglePlayPauseCommand}"
                                Classes="Basic"
                                Width="40"
                                Height="40">
                            <Panel>
                                <Svg Path="/Assets/pause-1006-svgrepo-com.svg"
                                     Width="22" Height="22"
                                     IsVisible="{Binding Player.IsPlayingAudio}" />
                                <Svg Path="/Assets/play-1003-svgrepo-com.svg"
                                     Width="22" Height="22"
                                     IsVisible="{Binding !Player.IsPlayingAudio}" />
                            </Panel>
                        </Button>
                        <Button Cursor="Hand"
                                Command="{Binding Player.PlayNextCommand}"
                                Classes="Basic"
                                ToolTip.Tip="下一首"
                                Width="32" Height="32">
                            <Svg Path="/Assets/next-svgrepo-com.svg" Width="16" Height="16" />
                        </Button>
                    </StackPanel>

                    <!-- 进度条 -->
                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto, *, Auto"
                          Width="380"
                          Margin="0,6,0,0">
                        <TextBlock
                            Text="{Binding Player.CurrentPositionSeconds, Converter={StaticResource SecondsToTimeConverter}}"
                            FontSize="10"
                            Opacity="0.45"
                            VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding Player.TotalDurationSeconds}"
                                Value="{Binding Player.CurrentPositionSeconds}"
                                Margin="10,0"
                                IsSnapToTickEnabled="False"
                                HorizontalAlignment="Stretch"
                                Classes="Player" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Player.TotalDurationSeconds, Converter={StaticResource SecondsToTimeConverter}}"
                                   FontSize="10"
                                   Opacity="0.45"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Grid>

                <!-- 右侧：音量 + 工具按钮 -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">

                    <!-- 音量控制 -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <Svg Path="/Assets/volume-max-svgrepo-com.svg"
                             Width="15" Height="15"
                             Opacity="0.7" />
                        <Slider Minimum="0"
                                Maximum="1"
                                Value="{Binding Player.MusicVolume}"
                                Width="76"
                                Classes="Player" />
                    </StackPanel>

                    <!-- 分隔感 -->
                    <Border Width="1" Height="20" Opacity="0.12" Background="Gray" Margin="4,0" />

                    <ComboBox Classes="QualityCombo"
                              ItemsSource="{Binding Player.QualityOptions}"
                              SelectedItem="{Binding Player.QualitySelection}"
                              IsEnabled="{Binding Player.IsSwitchingQuality, Converter={x:Static BoolConverters.Not}}"
                              VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="x:String">
                                <TextBlock
                                    Text="{Binding ., Converter={StaticResource PlaybackQualityDisplayConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.SelectionBoxItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding ., Converter={StaticResource PlaybackQualityDisplayConverter}}" />
                            </DataTemplate>
                        </ComboBox.SelectionBoxItemTemplate>
                    </ComboBox>

                    <!-- 队列按钮 -->
                    <Button Cursor="Hand"
                            Command="{Binding ToggleQueuePaneCommand}"
                            Classes="Basic"
                            ToolTip.Tip="播放列表"
                            Width="32" Height="32">
                        <Svg Path="/Assets/PlayList.svg" Width="18" Height="18" />
                    </Button>

                    <!-- 随机/顺序播放 -->
                    <Button Cursor="Hand"
                            Command="{Binding Player.ToggleShuffleModeCommand}"
                            Classes="Basic"
                            Width="32" Height="32">
                        <Panel>
                            <Svg Path="/Assets/shuffle-svgrepo-com.svg"
                                 Width="18" Height="18"
                                 IsVisible="{Binding Player.IsShuffleMode}" />
                            <Svg Path="/Assets/repeat-svgrepo-com.svg"
                                 Width="18" Height="18"
                                 IsVisible="{Binding !Player.IsShuffleMode}" />
                        </Panel>
                    </Button>

                    <!-- 桌面歌词 -->
                    <Button Cursor="Hand"
                            Command="{Binding ToggleDesktopLyricCommand}"
                            Classes="Basic"
                            ToolTip.Tip="桌面歌词"
                            Width="32" Height="32">
                        <Svg Path="/Assets/DesktopLyric2.svg"
                             Width="20" Height="20"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

            </Grid>
        </suki:GlassCard>
    </Grid>
</UserControl>
